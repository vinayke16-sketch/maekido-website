{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/dashboard/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|color|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, color, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:coral|sun|mint|sky|violet|ink)$/]",
        "message": "<Avatar> color must be one of 'coral' | 'sun' | 'mint' | 'sky' | 'violet' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, color, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:coral|sun|mint|sky|violet|ink)$/]",
        "message": "<Badge> color must be one of 'coral' | 'sun' | 'mint' | 'sky' | 'violet' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|iconRight|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, iconRight, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|coral|sun|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'coral' | 'sun' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|title|body|footer|interactive|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, icon, title, body, footer, interactive, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|warm|dark)$/]",
        "message": "<Card> variant must be one of 'light' | 'warm' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|size|style|key|ref|className|style|children)$/]",
        "message": "<IconTile> doesn't accept that prop. Declared props: children, color, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:coral|sun|mint|sky|violet|ink)$/]",
        "message": "<IconTile> color must be one of 'coral' | 'sun' | 'mint' | 'sky' | 'violet' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|pill|style|key|ref|className|style|children)$/]",
        "message": "<SectionLabel> doesn't accept that prop. Declared props: children, color, pill, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:coral|sun|mint|sky|violet|ink)$/]",
        "message": "<SectionLabel> color must be one of 'coral' | 'sun' | 'mint' | 'sky' | 'violet' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|variant|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, color, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:coral|sun|mint|sky|violet|ink)$/]",
        "message": "<Tag> color must be one of 'coral' | 'sun' | 'mint' | 'sky' | 'violet' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|outlined|solid)$/]",
        "message": "<Tag> variant must be one of 'soft' | 'outlined' | 'solid'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
